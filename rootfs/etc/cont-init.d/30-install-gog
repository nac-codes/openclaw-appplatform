#!/command/with-contenv bash
# Install gogcli (Google One Gateway) for Gmail/Calendar/Contacts access.
# Pins a specific release; idempotent — skips download if version already installed.
# Sets keyring passphrase via env so headless invocations don't prompt.

set -euo pipefail

GOG_VERSION="0.12.0"
GOG_BIN="/usr/local/bin/gog"

current_version=""
if [ -x "$GOG_BIN" ]; then
  current_version="$("$GOG_BIN" --version 2>/dev/null | awk '{print $1}' | tr -d 'v' || true)"
fi

if [ "$current_version" = "$GOG_VERSION" ]; then
  echo "[install-gog] gog v${GOG_VERSION} already installed at ${GOG_BIN}"
else
  arch="$(uname -m)"
  case "$arch" in
    x86_64|amd64) gog_arch="amd64" ;;
    aarch64|arm64) gog_arch="arm64" ;;
    *) echo "[install-gog] ERROR: unsupported arch $arch" >&2; exit 1 ;;
  esac

  url="https://github.com/steipete/gogcli/releases/download/v${GOG_VERSION}/gogcli_${GOG_VERSION}_linux_${gog_arch}.tar.gz"
  tmpdir="$(mktemp -d)"
  trap 'rm -rf "$tmpdir"' EXIT

  echo "[install-gog] Downloading gog v${GOG_VERSION} (${gog_arch}) from $url"
  curl -fsSL --retry 3 --retry-delay 2 -o "$tmpdir/gog.tar.gz" "$url"
  tar -xzf "$tmpdir/gog.tar.gz" -C "$tmpdir"

  src="$(find "$tmpdir" -type f -name 'gog' -perm -u+x | head -n 1)"
  if [ -z "$src" ]; then
    echo "[install-gog] ERROR: gog binary not found in archive" >&2
    ls -la "$tmpdir"
    exit 1
  fi

  install -m 0755 "$src" "$GOG_BIN"
  echo "[install-gog] Installed gog v${GOG_VERSION} -> ${GOG_BIN}"
fi

# Ensure credentials directory exists.
GOOGLE_CRED_DIR="/data/.openclaw/credentials/google"
mkdir -p "$GOOGLE_CRED_DIR"
chown -R openclaw:openclaw "$GOOGLE_CRED_DIR"
chmod 700 "$GOOGLE_CRED_DIR"

# Wire GOG_KEYRING_PASSWORD into the openclaw user's profile so every shell
# (interactive admin sessions and the runuser-launched gateway service) inherits it.
# Without this, gog file backend prompts for a TTY passphrase on each invocation.
PROFILE=/home/openclaw/.profile
touch "$PROFILE"
chown openclaw:openclaw "$PROFILE"

if [ -n "${GOG_KEYRING_PASSWORD:-}" ]; then
  if ! grep -q '^export GOG_KEYRING_PASSWORD=' "$PROFILE" 2>/dev/null; then
    {
      echo ''
      echo '# gog keyring (headless, non-interactive)'
      echo 'export GOG_KEYRING_BACKEND=file'
      echo "export GOG_KEYRING_PASSWORD='${GOG_KEYRING_PASSWORD}'"
    } >> "$PROFILE"
    echo "[install-gog] Wrote GOG_KEYRING_PASSWORD to $PROFILE"
  fi

  # Detect orphaned keyring files written with a stale/random passphrase.
  # Symptom: gog auth list fails with aes.KeyUnwrap integrity check failed.
  # Recovery: wipe the keyring directory; tokens are unrecoverable anyway.
  KR_DIR=/home/openclaw/.config/gogcli/keyring
  if [ -d "$KR_DIR" ] && [ -n "$(ls -A "$KR_DIR" 2>/dev/null)" ]; then
    if ! sudo -u openclaw bash -lc 'gog auth list >/dev/null 2>&1'; then
      echo "[install-gog] Detected unreadable keyring at $KR_DIR; wiping (tokens lost)"
      rm -rf "$KR_DIR"
      mkdir -p "$KR_DIR"
      chown -R openclaw:openclaw "/home/openclaw/.config/gogcli"
      chmod 700 "$KR_DIR"
    fi
  fi
else
  echo "[install-gog] WARNING: GOG_KEYRING_PASSWORD not set; gog will prompt for TTY passphrase"
fi

# Set keyring backend to file (idempotent).
sudo -u openclaw bash -lc 'gog auth keyring file' >/dev/null 2>&1 || \
  echo "[install-gog] WARNING: failed to set keyring backend"

echo "[install-gog] Done"
